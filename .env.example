# ═══════════════════════════════════════════════════
# Sohan Healthcare Task Manager — Environment Variables
# ═══════════════════════════════════════════════════
# Is file ko `.env` ke naam se rename karo aur values bharo

# ── Google Sheets (database) ─────────────────────────
# 1. Google Sheets me ek BLANK spreadsheet banao
# 2. Use service account ke saath share karo (Editor access):
#    akhileshvyas@reactwebappav.iam.gserviceaccount.com
# 3. Sheet ke URL se ID copy karo (.../spreadsheets/d/<ID>/edit)
#    ya poora URL bhi paste kar sakte ho — script ID extract kar lega
GOOGLE_SHEET_ID=PASTE_YOUR_GOOGLE_SHEET_ID_HERE

# ── App ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
SESSION_SECRET=change_this_to_a_random_long_string

# ── Email Automation (Gmail SMTP) — OPTIONAL ─────────
# 1. Gmail account me 2-Step Verification ON karo
# 2. https://myaccount.google.com/apppasswords se App Password banao
# 3. 16-character password (without spaces) yahan paste karo
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Sohan Healthcare Task Manager

# Aapke deployed app ka URL (email me link button ke liye)
APP_URL=http://localhost:3000
